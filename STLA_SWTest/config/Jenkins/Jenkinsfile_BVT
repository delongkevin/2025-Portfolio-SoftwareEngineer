            <tr><th>Live Console</th><td><a href="${BUILD_URL}console">View Live Console</a></td></tr>
            <tr><th>Software Test Report</th><td><a href="${BUILD_URL}artifact/BVTRBS/03_VariantDependent/Customer/CVADAS_RBS_TRSC/Software_Test_Report.html">View Test Report</a></td></tr>
        </table>
        <iframe src="${env.WORKSPACE}/BVTRBS/03_VariantDependent/Customer/CVADAS_RBS_TRSC/{params.Report_File_Name}"
