def ExecuteTest(Map args){
	script {
		print """
		=========================================================================
		TEST: ${args.param1} Qualification Test
		=========================================================================
        """
		try {
			bat(script: "${env.PY_EXE} ${env.CANOE_CONTROL} --openCANoeSimulation %WORKSPACE%\\03_VariantDependent\\Customer\\X120_MFK5_AR430\\FCA_L2H4060_MFK5_AR430_${args.param1}.cfg")
			sleep(10)
            bat(script: "${env.PY_EXE} ${env.CANOE_CONTROL} --startSimulation")
			bat(script: "${env.PY_EXE} ${env.CANOE_TEST_CONTROL} --runTest ${args.param2} --timeout ${args.param3}")
			sleep(10)
            bat(script: "${env.PY_EXE} ${env.CANOE_CONTROL} --stopSimulation")
			sleep(5)

			bat(script: "${env.PY_EXE} ${env.CANOE_CONTROL} --closeCANoe")
			sleep(5)
			currentBuild.result = 'SUCCESS'
		} catch (Exception e) {
			bat(script: "${env.PY_EXE} ${env.CANOE_CONTROL} --closeCANoe")
			echo "ERROR: System Stability Test FAILED"
			currentBuild.result = 'FAILED'
			error('FAILED')
		}
	}
}
