export Cycle_Time_Difference_NM_PAM()
{
  result = ChkStart_MsgRelCycleTimeViolation(NM_PAM, 0.9, 1.1);
  if(result > 0)
  {
    testStepPass(" ","Observed time difference of 1000ms between two NM_PAM messages");
  }
  else
  {
    testStepFail(" ","Not observed time difference of 1000ms between two NM_PAM messages");
  }    
}

export CAN_communication_Stop()
{
  canSetChannelOutput(1,0);
  canSetChannelOutput(2,0);
}

export CAN_communication_Start()
{ 
  canSetChannelOutput(1,1);
  canSetChannelOutput(2,1);
}

export Communincation_Restart()
{  
  Check_FD_CAN_2_trace();
  testwaitfortimeout(500);
  if(Rx_msg_CAN_1 == 0)
  {
      do
      {
          Check_FD_CAN_2_trace();
          testwaitfortimeout(1000);
          CAN_communication_Stop();
          testwaitfortimeout(2000);
          Power_Supply_OFF();
          testwaitfortimeout(2000);
          Set_voltage(syspar::Power_Control::RS_232_Port_Number,syspar::Power_Control::Normal_Voltage);
          testwaitfortimeout(2000);
          Power_Supply_ON();
          testwaitfortimeout(500);
          CAN_communication_Start();
          testwaitfortimeout(500);
          setSignal(CmdIgnSts,0x4);
          testwaitfortimeout(2000);
          if(testWaitForMessage(CVADAS::CVPAM_FD_Info,15) && testWaitForMessage(PDC_INFO_FD_PAM,1100))
          {
              //
          }
          else
          {
              testwaitfortimeout(2000);
              if(testWaitForMessage(CVADAS::CVPAM_FD_Info,15) && testWaitForMessage(PDC_INFO_FD_PAM,1100))
              {
                  testwaitfortimeout(2500);
              }
              else
              {
                //
              }
          }
          
      }while(Rx_msg_CAN_1 == 0);
  }
  else
  {
    //
  }
  
  @MEnv_Default_SET_BOL_1 = 0;
  testwaitfortimeout(100);
  @MEnv_Default_SET_BOL_1 = 1;
  testwaitfortimeout(4000);
  
}

export Hard_Reset_Function()
{  
  Check_FD_CAN_2_trace();
  testwaitfortimeout(1000);
  if(Rx_msg_CAN_1 == 0)
  {
      do
      {
          Check_FD_CAN_2_trace();
          testwaitfortimeout(1000);
          Power_Supply_OFF();
          testwaitfortimeout(2000);
          Set_voltage(syspar::Power_Control::RS_232_Port_Number,syspar::Power_Control::Normal_Voltage);
          testwaitfortimeout(2000);
          Power_Supply_ON();
          testwaitfortimeout(2000);
      }while(Rx_msg_CAN_1 == 0);
  }
  else
  {
    //
  }
}

export Reset_CAN()
{
  resetCanEx(1);
  testwaitfortimeout(2000);
  resetCanEx(1);
  testwaitfortimeout(2000);
}