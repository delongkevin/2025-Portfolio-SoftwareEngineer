export testcase FDF6_Runtimestats()
{
diagRequest CVADAS_0001_00000000_000._22FDF6_RunTimeStatsData_Read req;
diagResponse CVADAS_0001_00000000_000._22FDF6_RunTimeStatsData_Read resp;

dword responseDataLength;
byte rawResponseData[4096]; // Use a large enough buffer for extended responses
dword i;
dword logFileHandle;
char filePath[500] = "RunTimeStats_FDF6.txt";
char logString[500];
  
diagSendRequest(req);
testWaitForDiagResponse(req, 10000);
logFileHandle = openFileWrite(filePath, 0);

  if (diagIsPositiveResponse(resp))
  {
    // Get the length and fill the buffer with the raw response data
    responseDataLength = elCount(rawResponseData);
    if (diagGetPrimitiveData(resp, rawResponseData, responseDataLength) == 0)
    {
      snprintf(logString, elcount(logString), "%s: Positive response for DID. Raw data:", timeNow());
      filePutString(logString, strlen(logString), logFileHandle);
      write ("%s", logString);
      
      // Print all bytes of the response
      for (i = 0; i < responseDataLength; i++)
      {
        snprintf(logString, elcount(logString), " %02X", rawResponseData[i]);
        filePutString(logString,strlen(logString), logFileHandle);
        write ("%s", logString);
      }
      filePutString("\n",5, logFileHandle); // Add newline
    }
  }
  else
  {
    // Log negative response
    snprintf(logString, elcount(logString), "%s: Negative response received. Error code: 0x%X\n", timeNow(), diagGetResponseCode(resp));
    filePutString(logString,strlen(logString), logFileHandle);
  }
  
  fileClose(logFileHandle);
}

export void General_Precondition()
{
  long response;
  Enable_CAN_Communication();
  diagStopTesterPresent();
  diagStopTesterPresent();
  
  testStep("","Set TGW_CAMERA_DISP_STAT = 4 (Surround View configuration)");
  setSignal(TGW_CAMERA_DISP_STAT,4);
  $TGW_CAMERA_DISP_STAT == 4;
  
  testStep("", "Wait for 7000 ms");
  testWaitForTimeout(7000);
  
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 0;
  
}

export testcase HMI_View_Robustness(int gear, int angle, int ignition)
{
  long response, i;
  General_Precondition();
  $TargetGear=ignition;
  $CmdIgnSts=ignition;
  $ShiftLeverPosition = gear; 
  //$LwsAngle_SCCM = angle;
  $SVC_Guidelines=1;
  $Fwrd_Cam_Guidelines=1;
  testStep("","Gear is set to: %d", gear);
  testStep("","Ignition set to: %d", ignition);
  testStep("","Steering Angle is set to: %d",angle);
  for(i = 1; i <= 15; i++)
  {
    $CameraDisplaySts2 = i;
    response = testWaitForSyscall("","python CaptureImage.pyw",1,8000); // default directory root of canoe rbs,  run python script to capture image, timeout is 8 seconds. exit code is 1 from python script.
    if (response != 1)
    {
      testStepFail("","Failed to capture from image grabber!");
    }
    else
    {
      testStepPass("Successfully captured Image from image grabber!");
    }
    Check_Both_Can_Messages();
  }
  General_Postcondition();
}

export void General_Postcondition()
{
  long response;
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 2;
  
}

