export CAN_communication_Stop()
{
  canSetChannelOutput(1,0);
  canSetChannelOutput(2,0);
}

export CAN_communication_Start()
{ 
  canSetChannelOutput(1,1);
  canSetChannelOutput(2,1);
}


export void Retry(char functionName[])
{
  int retries;
  long response;
  
  retries = 0;
  testWaitForTimeout(15000);  //Wait for ECU to get ready..
  do
  {
    if(retries == 0) //print the test step at first try.
    {
      testStep("", "Try %s", functionName);
    }
    else
    {
      testStep("", "Retry %s, error code %d", functionName, response);
    }
    if(strncmp(functionName, "Set_Default_Session", 19) == 0)
    {
      response = Set_Default_Session();
    }
    else if(strncmp(functionName, "Set_Programming_Session", 23) == 0)
    {
      response = Set_Programming_Session();
    }
    else if(strncmp(functionName, "Set_Extended_Session", 20) == 0)
    {
      response = Set_Extended_Session();
    }
    else if(strncmp(functionName, "Hard_Reset", 10) == 0)
    {
      response = Hard_Reset();
    }
    else if(strncmp(functionName, "Write_Proxy", 11) == 0)
    {
      response = Write_Proxy();
    }
    else
    {
      testStepFail("", "Function not found to retry");
      return;
    }
    
    if(response == 1){
      testStepPass("","%s succeeded", functionName);
      return;
    }
    
    retries += 1;
    testStep("", "Wait for 10 seconds");
    testWaitForTimeout(10000);
  }
  while(retries < 3);
  //Exiting do while, if reached here, test step failed.  Otherwise it will return for response = 1 for test step pass.
  testStepFail("","%s failed, error code: %d", functionName, response);
}

export long Set_Programming_Session()
{
  long response;
  diagRequest CVADAS_0001_00000000_000.Programming_Session_Start programmingSessionStart;
  
  testStep("","Set Programming Session");
  programmingSessionStart.SendRequest();
  response = TestWaitForDiagRequestSent(programmingSessionStart, 15000);
  response = testWaitForDiagResponse(programmingSessionStart, 15000);
  return response;
  
}

export long Write_Proxy()
{
  long response;
  diagRequest CVADAS_0001_00000000_000._2E2023_PROXI_Data proxiData;

  
  testStep("", "Write proxi data");
  proxiData.SetParameter("_Data_24", "");
  proxiData.SendRequest();
  response = TestWaitForDiagResponse(proxiData, 1000);
  if(response == 1)
  {
    response = diagGetLastResponseCode(proxiData);
    if(response == -1)
    {
      return 1;
    }
    if(response == 1){
      return -1;
    }
  }
  return response;
}

