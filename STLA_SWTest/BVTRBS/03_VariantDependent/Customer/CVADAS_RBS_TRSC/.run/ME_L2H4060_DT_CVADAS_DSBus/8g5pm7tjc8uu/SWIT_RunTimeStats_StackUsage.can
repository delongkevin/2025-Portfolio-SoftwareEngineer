  Enable_CAN_Communication();
  Switch_Gear_With_String("R");
  testwaitfortimeout(10000);
  PowerSupply_Control("VOLT060\r");
  Switch_Gear_With_String("D");
  Power_Cycle(10000);
  strncpy(defaultImageName, "Drive-Gear", 80);
