  Power_Cycle(10000);
  strncpy(defaultImageName, "Park-Gear", 80);
  strncat(defaultImageName, timeStampInString, 80);
  Capture_Image(defaultImageName,"1200x900");
  PowerSupply_Control("VOLT170\r");
  Switch_Gear_With_String("R");
  Power_Cycle(10000);
  strncpy(defaultImageName, "Reverse-Gear", 80);
  strncat(defaultImageName, timeStampInString, 80);
  Capture_Image(defaultImageName,"1200x900");
  Switch_Gear_With_String("N");
  Power_Cycle(10000);
  PowerSupply_Control("VOLT135\r");
  strncpy(defaultImageName, "Netural-Gear", 80);
