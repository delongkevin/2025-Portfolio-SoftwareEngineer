  //Check HMI
   for (j = 0; j < 15; j++)  {
   $CameraDisplaySts2 = j;
    testWaitForTimeout(15000);
  snprintf(defaultImageName, elcount(defaultImageName), "CameraDisplaySts_%d", j);
  strncat(defaultImageName, timeStampInString, 80);
  Capture_Image(defaultImageName,"1200x900");
    }
  Set_Extended_Session();

  FD64request.SendRequest();
  testWaitForDiagRequestSent(FD64request, 2000);
  FD64response.GetLastResponse();
  i = diagGetPrimitiveData(FD64response, response, elcount(response));
  
    for (k = 0; k<=i; k++)
    {
      snprintf(tmp, elcount(tmp), "%X", response[k]);
      strncat(out, tmp, elcount(out));
    }
  teststep("","FD64 Readout: %s",out);
  out[0] = 0; //clear output string
    
  batteryvoltreq.SendRequest();
  testWaitForDiagRequestSent(batteryvoltreq, 2000);
  batteryvoltresp.GetLastResponse();
  i = diagGetPrimitiveData(batteryvoltresp, response, elcount(response));
  
    for (k = 0; k<=i; k++)
    {
      snprintf(tmp, elcount(tmp), "%X", response[k]);
      strncat(out, tmp, elcount(out));
    }
  teststep("","Battery Read: %s",out);
    
  out[0] = 0; //clear output string
  FD4Arequest.SendRequest();
  testWaitForDiagRequestSent(FD4Arequest, 2000);
  FD4Aresponse.GetLastResponse();
  i = diagGetPrimitiveData(FD4Aresponse, response, elcount(response));

    for (k = 0; k<=i; k++)
    {
      snprintf(tmp, elcount(tmp), "%X", response[k]);
      strncat(out, tmp, elcount(out));
    }
  teststep("","USS Current/voltage read(FD4A): %s",out);


  //Check DTCs
  Check_DTC();

  //prepare for next cycle
  General_Postcondition();
  
}



