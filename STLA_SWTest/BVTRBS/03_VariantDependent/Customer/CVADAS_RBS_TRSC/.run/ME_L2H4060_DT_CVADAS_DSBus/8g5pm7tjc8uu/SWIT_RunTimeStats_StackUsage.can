}

export void Main_Precondition()
{
  
  @sysvar::IL::Klemme15=1;
  @sysvar::IL::Klemme30=1;
  testStep("", "Ignition and power turned on");
  
  $CmdIgnSts = 4;
  testStep("", "$CmdIgnSts set to 'on'");
  
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 0;
  
  testStep("", "Set Gear to Park");
  $ShiftLeverPosition = 1;
  
  testWaitForTimeout(15000); //boot up
  testStepPass("","ECU is powered up successfully!");
  
  $TGW_CAMERA_DISP_STAT=4;
  $Fwrd_Cam_Guidelines=1;
  $SVC_Guidelines=1;
 // $LwsAngle_SCCM=0;
  
  
  
}

export void Main_Postcondition()
{
   testStepPass("","ECU Test has been completed!");
}

