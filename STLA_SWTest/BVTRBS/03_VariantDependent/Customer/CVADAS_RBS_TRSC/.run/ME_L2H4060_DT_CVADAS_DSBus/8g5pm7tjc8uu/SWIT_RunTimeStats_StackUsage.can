export testcase Gear_Switch_Test()
{
  char timeStampInString[10];
  char takenImageName[50];
  int i = 0;
  
  for(i = 0; i<= 10; i++) 
  {
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 0;
  
  Switch_Gear_With_String("P");
  
  testStep("", "Wait 2 seconds");
  testWaitForTimeout(2000);
  snprintf(takenImageName, elcount(takenImageName), "%d-Park-Gear", i);
  Capture_Image(takenImageName, "1200x900");
  
  Switch_Gear_With_String("R");
  
  testStep("", "Wait 2 seconds");
  testWaitForTimeout(2000);
  
  snprintf(takenImageName, elcount(takenImageName), "%d-Reverse-Gear", i);
  Capture_Image(takenImageName, "1200x900");
  
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 0;
  
  Switch_Gear_With_String("D");
  
  testStep("", "Wait 2 seconds");
  testWaitForTimeout(2000);
  
  snprintf(takenImageName, elcount(takenImageName), "%d-Drive-Gear", i);
  Capture_Image(takenImageName, "1200x900");
  
  }
}

