}

export testcase Sleep_Wakeup_Interrupt(long starttimer, long incrementtimer, long stoptimer)
{
  long i, j;
  char view[5];
  char timeStampInString[10];
  char batchFileNameWithASpace [50] = "Image_Comparison.bat ";
  char fullCommand [256] = "";
  long response;
  char takenImageName[16];
  char masterImageName[16];
  long k;
  j = 0;
  General_Precondition();
  Clear_DTC();
  
  for (i = starttimer; i <= stoptimer; i = i + incrementtimer)
  {
    testStep("","Start: %d \n End: %d \n Increment: %d \n Delta: %d",starttimer, stoptimer, incrementtimer, i);
    testWaitForTimeout(starttimer); 
    Disable_CAN_Communcation_NoSleep();  // Turns off igntion/power - no sleep time in function
    testWaitForTimeout(stoptimer);  
    Enable_CAN_Communication();  // Turns on ignition/power
    testWaitForTimeout(i);  
    write("Start: %d, Stop: %d, Increment: %d Delta: %d",starttimer,stoptimer, incrementtimer, i);
    $CmdIgnSts = 4;
    Switch_Gear_With_String("P");
    $CameraDisplaySts2 = 2;
    ltoa(i, timeStampInString, 10);
    Capture_Image(timeStampInString,"1200x900"); //Check HMI
    if ($CVADAS::DisplayView2 == 0) { testStepFail("","DisplayView2 == %d",$CVADAS::DisplayView2); }
    else  { testStepPass(); }
   }
  
  Check_DTC();
  General_Postcondition();
}


