export void parsePartNumbers()
{
  long response, retries;
  char batchFileNameWithASpace [250] = "Parse_Excel.bat ";
  char fullCommand [256] = "";
  
  setFilePath(batchFileNameWithASpace,0);
  
  retries = 0;
  strncpy(fullCommand, batchFileNameWithASpace, 256);
  
  testStep("", "Start parsing part numbers");
  response = testWaitForSyscall(batchFileNameWithASpace, fullCommand, 0, 60000);

}

export void PowerSupply_Control(char vtg[])
{
  dword length, port;
  int i, response;
  byte buffer[100];
  
  port = 8;//EAHMSJENKINS33 PC
  
  rs232Open(port);
  length = strlen(vtg); 
  for(i=0;i<=length;i++) { buffer[i]= vtg[i]; }
  response = RS232Send(port,buffer,length);
  RS232Receive(port, buffer, 100);

  if (response != 1 )  { write("Failed to send %s to power supply", vtg); } 
  else { testStepPass("", "Sent command to power supply: %s",vtg); }
}

export Power_Supply_OFF()
{
  PowerSupply_Control("SOUT1\r"); //OFF
}

export Power_Supply_ON()
{
  PowerSupply_Control("SOUT0\r"); //ON
}


export double Power_Supply_Get_Voltage()
{
  double voltage;
 // voltage = Run_Power_Supply_Batch_File("readVoltage");
  
