export testcase FDF6(int iterations, char path[], int waitTime)
{
  diagRequest CVADAS_0001_00000000_000._22FDF6_RunTimeStatsData_Read req;
  diagResponse CVADAS_0001_00000000_000._22FDF6_RunTimeStatsData_Read resp;
  
  byte response[500];
  char outBuffer[1000];
  char temp[200]; // Temporary buffer for snprintf
  int len;
  dword logFile;
  dword resp_diag;
  int i, j;
  int offset;
  char hex_str[20];
  
  // Declare task name arrays without initialization
  char mcu1_0_tasks[19][50];
  char mcu2_1_tasks[11][50];
  char mcu2_0_tasks[8][50];
  char a_core_tasks[31][50];
  
  // Initialize task names at runtime
  for (j = 0; j < 19; j++) mcu1_0_tasks[j][0] = '\0';
  strncat(mcu1_0_tasks[0], "BootAppOsTask", elcount(mcu1_0_tasks[0]) - 1);
  strncat(mcu1_0_tasks[1], "IdleTask_OsCore0", elcount(mcu1_0_tasks[1]) - 1);
  strncat(mcu1_0_tasks[2], "QM_ComTask_10ms", elcount(mcu1_0_tasks[2]) - 1);
  strncat(mcu1_0_tasks[3], "QM_ComTask_5ms", elcount(mcu1_0_tasks[3]) - 1);
  strncat(mcu1_0_tasks[4], "QM_DiagTask_10ms", elcount(mcu1_0_tasks[4]) - 1);
  strncat(mcu1_0_tasks[5], "QM_MemTask_10ms", elcount(mcu1_0_tasks[5]) - 1);
  strncat(mcu1_0_tasks[6], "QM_Task_00_10ms", elcount(mcu1_0_tasks[6]) - 1);
  strncat(mcu1_0_tasks[7], "QM_Task_01_10ms", elcount(mcu1_0_tasks[7]) - 1);
  strncat(mcu1_0_tasks[8], "QM_Task_200ms", elcount(mcu1_0_tasks[8]) - 1);
  strncat(mcu1_0_tasks[9], "QM_Task_Init", elcount(mcu1_0_tasks[9]) - 1);
  strncat(mcu1_0_tasks[10], "Safety_Task_00_10", elcount(mcu1_0_tasks[10]) - 1);
  strncat(mcu1_0_tasks[11], "Safety_Task_01_10", elcount(mcu1_0_tasks[11]) - 1);
  strncat(mcu1_0_tasks[12], "Safety_Task_200ms", elcount(mcu1_0_tasks[12]) - 1);
  strncat(mcu1_0_tasks[13], "Safety_Task_Init", elcount(mcu1_0_tasks[13]) - 1);
  strncat(mcu1_0_tasks[14], "Safety_WdgTask_10ms", elcount(mcu1_0_tasks[14]) - 1);
  strncat(mcu1_0_tasks[15], "SciServerHighOsTask", elcount(mcu1_0_tasks[15]) - 1);
  strncat(mcu1_0_tasks[16], "SciServerLowOsTask", elcount(mcu1_0_tasks[16]) - 1);
  strncat(mcu1_0_tasks[17], "ShutdownTask", elcount(mcu1_0_tasks[17]) - 1);
  strncat(mcu1_0_tasks[18], "StartUpTask", elcount(mcu1_0_tasks[18]) - 1);
  
  for (j = 0; j < 11; j++) mcu2_1_tasks[j][0] = '\0';
  strncat(mcu2_1_tasks[0], "en_Task_BSW_B_Idle", elcount(mcu2_1_tasks[0]) - 1);
  strncat(mcu2_1_tasks[1], "en_Task_BSW_B_1msec", elcount(mcu2_1_tasks[1]) - 1);
  strncat(mcu2_1_tasks[2], "en_Task_BSW_B_10msec", elcount(mcu2_1_tasks[2]) - 1);
  strncat(mcu2_1_tasks[3], "en_TasK_BSW_QM_10msec", elcount(mcu2_1_tasks[3]) - 1);
  strncat(mcu2_1_tasks[4], "en_TasK_BSW_QM1_10msec", elcount(mcu2_1_tasks[4]) - 1);
  strncat(mcu2_1_tasks[5], "en_Task_BSW_QM_UssCfg", elcount(mcu2_1_tasks[5]) - 1);
  strncat(mcu2_1_tasks[6], "en_Task_en_TasK_BSW_QM_HighPriority_OnEvent", elcount(mcu2_1_tasks[6]) - 1);
  strncat(mcu2_1_tasks[7], "en_Task_APP_B_30msec", elcount(mcu2_1_tasks[7]) - 1);
  strncat(mcu2_1_tasks[8], "en_TasK_APP_QM_30msec", elcount(mcu2_1_tasks[8]) - 1);
  strncat(mcu2_1_tasks[9], "en_Task_SAFETY_APP_50msec", elcount(mcu2_1_tasks[9]) - 1);
  strncat(mcu2_1_tasks[10], "en_TasK_SAFETY_BSW_10msec", elcount(mcu2_1_tasks[10]) - 1);
  
  for (j = 0; j < 8; j++) mcu2_0_tasks[j][0] = '\0';
  strncat(mcu2_0_tasks[0], "en_Task_BSW_B_10msec", elcount(mcu2_0_tasks[0]) - 1);
  strncat(mcu2_0_tasks[1], "en_TasK_BSW_QM_10msec", elcount(mcu2_0_tasks[1]) - 1);
  strncat(mcu2_0_tasks[2], "en_TasK_BSW_QM1_10msec", elcount(mcu2_0_tasks[2]) - 1);
  strncat(mcu2_0_tasks[3], "en_Task_en_TasK_BSW_QM_HighPriority_OnEvent", elcount(mcu2_0_tasks[3]) - 1);
  strncat(mcu2_0_tasks[4], "en_TasK_BSW_QM_TI_10msec", elcount(mcu2_0_tasks[4]) - 1);
  strncat(mcu2_0_tasks[5], "en_Task_APP_B_10msec", elcount(mcu2_0_tasks[5]) - 1);
  strncat(mcu2_0_tasks[6], "en_TasK_APP_QM_10msec", elcount(mcu2_0_tasks[6]) - 1);
  strncat(mcu2_0_tasks[7], "en_Task_APP_B_30msec", elcount(mcu2_0_tasks[7]) - 1);
  
  for (j = 0; j < 31; j++) a_core_tasks[j][0] = '\0';
  strncat(a_core_tasks[0], "APA", elcount(a_core_tasks[0]) - 1);
  strncat(a_core_tasks[1], "CALSM", elcount(a_core_tasks[1]) - 1);
  strncat(a_core_tasks[2], "CALSM_Thread", elcount(a_core_tasks[2]) - 1);
  strncat(a_core_tasks[3], "DLDThread", elcount(a_core_tasks[3]) - 1);
  strncat(a_core_tasks[4], "DLD", elcount(a_core_tasks[4]) - 1);
  strncat(a_core_tasks[5], "EOL", elcount(a_core_tasks[5]) - 1);
  strncat(a_core_tasks[6], "EOLThread", elcount(a_core_tasks[6]) - 1);
  strncat(a_core_tasks[7], "MOT", elcount(a_core_tasks[7]) - 1);
  strncat(a_core_tasks[8], "OC", elcount(a_core_tasks[8]) - 1);
  strncat(a_core_tasks[9], "OCThread", elcount(a_core_tasks[9]) - 1);
  strncat(a_core_tasks[10], "OD", elcount(a_core_tasks[10]) - 1);
  strncat(a_core_tasks[11], "OVL3D", elcount(a_core_tasks[11]) - 1);
  strncat(a_core_tasks[12], "RenderThread", elcount(a_core_tasks[12]) - 1);
  strncat(a_core_tasks[13], "TAD2", elcount(a_core_tasks[13]) - 1);
  strncat(a_core_tasks[14], "TAD2Thread", elcount(a_core_tasks[14]) - 1);
  strncat(a_core_tasks[15], "TIOVX", elcount(a_core_tasks[15]) - 1);
  strncat(a_core_tasks[16], "CameraCalib", elcount(a_core_tasks[16]) - 1);
  strncat(a_core_tasks[17], "VideoInput", elcount(a_core_tasks[17]) - 1);
  strncat(a_core_tasks[18], "AppM", elcount(a_core_tasks[18]) - 1);
  strncat(a_core_tasks[19], "LogM", elcount(a_core_tasks[19]) - 1);
  strncat(a_core_tasks[20], "KeepAlive", elcount(a_core_tasks[20]) - 1);
  strncat(a_core_tasks[21], "ThreadMsgSndr", elcount(a_core_tasks[21]) - 1);
  strncat(a_core_tasks[22], "SigM", elcount(a_core_tasks[22]) - 1);
  strncat(a_core_tasks[23], "ThreadSigM", elcount(a_core_tasks[23]) - 1);
  strncat(a_core_tasks[24], "Sys", elcount(a_core_tasks[24]) - 1);
  strncat(a_core_tasks[25], "SysMon", elcount(a_core_tasks[25]) - 1);
  strncat(a_core_tasks[26], "VarM", elcount(a_core_tasks[26]) - 1);
  strncat(a_core_tasks[27], "AlgoViewThread", elcount(a_core_tasks[27]) - 1);
  strncat(a_core_tasks[28], "InputBuffer", elcount(a_core_tasks[28]) - 1);
  strncat(a_core_tasks[29], "TAD3", elcount(a_core_tasks[29]) - 1);
  strncat(a_core_tasks[30], "TAD3Thread", elcount(a_core_tasks[30]) - 1);
  
  // Validate file path and open file
  setFilePath(path, 1);
  logFile = openFileWrite("RunTimeStats_FDF6.txt", 2); // Use 0 to overwrite for debugging
  if (logFile == 0)
  {
    write("Error: Failed to open file at path %s", path);
    testStepFail("Failed to open log file!");
    return;
  }
  
  for (i = 1; i <= iterations; i++)
  {
    write("Starting iteration %d", i);
    testWaitForTimeout(waitTime); //~2 mins
   
    // Read Runtime stats
    Set_Extended_Session();
    req.SendRequest();
    resp_diag = testWaitForDiagResponse(req, 10000);
    if (resp_diag == 0)
    {
      write("Error: No response for read request");
      testStepFail("RunTime Stats Read - No Response!");
      snprintf(temp, elcount(temp), "Iteration %d: RunTime Stats Read - No Response\n", i);
      filePutString(temp, strlen(temp), logFile);
      fileClose(logFile);
      return;
    }
    diagGetLastResponse(resp);
    resp_diag = diagGetResponseCode(resp);
    write("Read response code: %d", resp_diag);
    if (resp_diag == -1)
    {
      testStepPass("RunTime Stats Read Successful!");
    }
    else
    {
      testStepFail("","RunTime Stats Read Failed! Response code: %d", resp_diag);
      snprintf(temp, elcount(temp), "Iteration %d: RunTime Stats Read Failed, code: %d\n", i, resp_diag);
      filePutString(temp, strlen(temp), logFile);
      fileClose(logFile);
      return;
    }
    
    // Get response data
    len = diagGetPrimitiveData(resp, response, 500);
    write("Response length: %d bytes", len);
    snprintf(temp, elcount(temp), "Iteration %d: Response length = %d bytes\n", i, len);
    filePutString(temp, strlen(temp), logFile);
    
    if (len <= 0)
    {
      write("Error: No data received in response");
      testStepFail("No data in RunTime Stats response!");
      snprintf(temp, elcount(temp), "Iteration %d: No data received\n", i);
      filePutString(temp, strlen(temp), logFile);
      continue; // Skip to next iteration
    }
    
    // Log raw response for debugging
    write("Raw response bytes:");
    for (j = 0; j < len; j++)
    {
      write(" %02X", response[j]);
    }
    
    // Convert byte array to hex string
    outBuffer[0] = 0;
    for (j = 0; j < len; j++)
    {
      char tmpHex[10];
      snprintf(tmpHex, elcount(tmpHex), "%02X ", response[j]);
      strncat(outBuffer, tmpHex, elcount(outBuffer) - strlen(outBuffer) - 1);
      if ((j + 1) % 16 == 0)
      {
        strncat(outBuffer, "\n", elcount(outBuffer) - strlen(outBuffer) - 1);
      }
    }
    
    // Log hex to test report and file
    testStepPass("RunTimeStats (Hex)", "%s", outBuffer);
    snprintf(temp, elcount(temp), "Iteration %d: RunTimeStats Hex Data:\n%s\n", i, outBuffer);
    filePutString(temp, strlen(temp), logFile);
    
    // Parse and log physical values (improved parsing)
    if (len < 298) // Minimum expected length for all sections
    {
      snprintf(temp, elcount(temp), "Warning: Response too short for full parsing (%d bytes)\n", len);
      filePutString(temp, strlen(temp), logFile);
    }
    
    offset = 3;
    
    // MCU1_0 section: 19 tasks, 4 bytes each, divisor 100.0
    snprintf(temp, elcount(temp), "Rx\t    MCU1_0\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 76 && offset + j < len; j++) // 19*4=76 bytes
    {
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
      if ((j + 1) % 20 == 0 || j == 75)
      {
        snprintf(temp, elcount(temp), "\n");
        filePutString(temp, strlen(temp), logFile);
        if (j < 75)
        {
          snprintf(temp, elcount(temp), "Rx\t\t    ");
          filePutString(temp, strlen(temp), logFile);
        }
      }
    }
    for (j = 0; j < 19 && offset + 4 <= len; j++)
    {
      long period_val;
      long time_val;
      float period;
      float avg_time;
      period_val = (response[offset] << 8) | response[offset + 1];
      time_val = (response[offset + 2] << 8) | response[offset + 3];
      period = (float)period_val / 100.0;
      avg_time = (float)time_val / 100.0;
      hex_str[0] = '\0'; // Initialize
      if (period_val == 0 && time_val == 0)
      {
        strncat(hex_str, "0x00", elcount(hex_str) - strlen(hex_str) - 1);
      }
      else
      {
        char tmpHexPart[20];
        snprintf(tmpHexPart, elcount(tmpHexPart), "%02X%02X%02X%02X", response[offset], response[offset+1], response[offset+2], response[offset+3]);
        strncat(hex_str, "0x", elcount(hex_str) - strlen(hex_str) - 1);
        strncat(hex_str, tmpHexPart, elcount(hex_str) - strlen(hex_str) - 1);
      }
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %s\n", mcu1_0_tasks[j], hex_str);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .AverageTime\t    %.2f [ms]\n", mcu1_0_tasks[j], avg_time);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .Average Periodicity\t    %.2f [ms]\n", mcu1_0_tasks[j], period);
      filePutString(temp, strlen(temp), logFile);
      offset += 4;
    }
    
    // MCU2_1 section: 11 tasks, 6 bytes each, divisor 1000.0
    snprintf(temp, elcount(temp), "Rx\t    MCU2_1\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 66 && offset + j < len; j++)
    {
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
      if ((j + 1) % 20 == 0 || j == 65)
      {
        snprintf(temp, elcount(temp), "\n");
        filePutString(temp, strlen(temp), logFile);
        if (j < 65)
        {
          snprintf(temp, elcount(temp), "Rx\t\t    ");
          filePutString(temp, strlen(temp), logFile);
        }
      }
    }
    for (j = 0; j < 11 && offset + 6 <= len; j++)
    {
      long period_val;
      long time_val;
      float period;
      float avg_time;
      period_val = (response[offset] << 16) | (response[offset + 1] << 8) | response[offset + 2];
      time_val = (response[offset + 3] << 16) | (response[offset + 4] << 8) | response[offset + 5];
      avg_time = (float)time_val / 1000.0;
      period = (float)period_val / 1000.0;
      hex_str[0] = '\0'; // Initialize
      if (period_val == 0 && time_val == 0)
      {
        strncat(hex_str, "0x00", elcount(hex_str) - strlen(hex_str) - 1);
      }
      else
      {
        char tmpHexPart[30];
        snprintf(tmpHexPart, elcount(tmpHexPart), "%02X %02X %02X %02X %02X %02X", 
                 response[offset], response[offset+1], response[offset+2], 
                 response[offset+3], response[offset+4], response[offset+5]);
        //strncat(hex_str, "0x", elcount(hex_str) - strlen(hex_str) - 1);
        //strncat(hex_str, tmpHexPart, elcount(hex_str) - strlen(hex_str) - 1);
        snprintf(hex_str, elcount(hex_str), "0x%s", tmpHexPart);
      }
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %s\n", mcu2_1_tasks[j], hex_str);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .AverageTime\t    %.3f [ms]\n", mcu2_1_tasks[j], avg_time); // Use %.3f for more precision as in log
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .Average Periodicity\t    %.3f [ms]\n", mcu2_1_tasks[j], period);
      filePutString(temp, strlen(temp), logFile);
      offset += 6;
    }
    //offset += 3;
    // MCU2_0 section: 8 tasks, 4 bytes each, divisor 100.0
    snprintf(temp, elcount(temp), "Rx\t    MCU2_0\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 32 && offset + j < len; j++)
    {
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
      if ((j + 1) % 20 == 0 || j == 31)
      {
        snprintf(temp, elcount(temp), "\n");
        filePutString(temp, strlen(temp), logFile);
        if (j < 31)
        {
          snprintf(temp, elcount(temp), "Rx\t\t    ");
          filePutString(temp, strlen(temp), logFile);
        }
      }
    }
    for (j = 0; j < 8 && offset + 4 <= len; j++)
    {
      long period_val;
      long time_val;
      float period;
      float avg_time;
      period_val = (response[offset] << 8) | response[offset + 1];
      time_val = (response[offset + 2] << 8) | response[offset + 3];
      avg_time = (float)time_val / 100.0;
      period = (float)period_val / 100.0;
      hex_str[0] = '\0'; // Initialize
      if (period_val == 0 && time_val == 0)
      {
        strncat(hex_str, "0x00", elcount(hex_str) - strlen(hex_str) - 1);
      }
      else
      {
        char tmpHexPart[20];
        snprintf(tmpHexPart, elcount(tmpHexPart), "%02X%02X%02X%02X", response[offset], response[offset+1], response[offset+2], response[offset+3]);
        strncat(hex_str, "0x", elcount(hex_str) - strlen(hex_str) - 1);
        strncat(hex_str, tmpHexPart, elcount(hex_str) - strlen(hex_str) - 1);
      }
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %s\n", mcu2_0_tasks[j], hex_str);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .AverageTime\t    %.2f [ms]\n", mcu2_0_tasks[j], avg_time);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .Average Periodicity\t    %.2f [ms]\n", mcu2_0_tasks[j], period);
      filePutString(temp, strlen(temp), logFile);
      offset += 4;
    }
    
    // A CORE section: 31 tasks, 4 bytes each, divisor 100.0 (all zero in example)
    snprintf(temp, elcount(temp), "Rx\t    A CORE\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 124 && offset + j < len; j++)
    {
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
      if ((j + 1) % 20 == 0 || j == 123)
      {
        snprintf(temp, elcount(temp), "\n");
        filePutString(temp, strlen(temp), logFile);
        if (j < 123)
        {
          snprintf(temp, elcount(temp), "Rx\t\t    ");
          filePutString(temp, strlen(temp), logFile);
        }
      }
    }
    for (j = 0; j < 31 && offset + 4 <= len; j++)
    {
      long period_val;
      long time_val;
      float period;
      float avg_time;
      period_val = (response[offset] << 8) | response[offset + 1];
      time_val = (response[offset + 2] << 8) | response[offset + 3];
      period = (float)period_val / 100.0;
      avg_time = (float)time_val / 100.0;
      hex_str[0] = '\0'; // Initialize
      if (period_val == 0 && time_val == 0)
      {
        strncat(hex_str, "0x00", elcount(hex_str) - strlen(hex_str) - 1);
      }
      else
      {
        char tmpHexPart[20];
        snprintf(tmpHexPart, elcount(tmpHexPart), "%02X%02X%02X%02X", response[offset], response[offset+1], response[offset+2], response[offset+3]);
        strncat(hex_str, "0x", elcount(hex_str) - strlen(hex_str) - 1);
        strncat(hex_str, tmpHexPart, elcount(hex_str) - strlen(hex_str) - 1);
      }
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %s\n", a_core_tasks[j], hex_str);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .AverageTime\t    %.2f [ms]\n", a_core_tasks[j], avg_time);
      filePutString(temp, strlen(temp), logFile);
      snprintf(temp, elcount(temp), "Rx\t    %s .Average Periodicity\t    %.2f [ms]\n", a_core_tasks[j], period);
      filePutString(temp, strlen(temp), logFile);
      offset += 4;
    }
  }
  fileClose(logFile);
}

export testcase FDF8(int iterations, char path[], int waitTime)
{
  diagRequest CVADAS_0001_00000000_000._22FDF8_StackUsage_Read req;
  diagResponse CVADAS_0001_00000000_000._22FDF8_StackUsage_Read resp;
  
  byte response[500];
  char outBuffer[1000];
  char temp[200];
  int len;
  dword logFile;
  dword resp_diag;
  int i, j;
  int offset;
  int stack_usage = 0;
  int mcu1_0_values[19];
  int mcu2_1_values[10];
  int mcu2_0_values[8];
  
  // Declare task name arrays in ORIGINAL ORDER (as data comes in)
  char mcu1_0_tasks[19][50];
  char mcu2_1_tasks[10][50];
  char mcu2_0_tasks[8][50];
  
  // Initialize MCU1_0 task names (ORIGINAL ORDER - matches data order)
  for (j = 0; j < 19; j++) mcu1_0_tasks[j][0] = '\0';
  strncat(mcu1_0_tasks[0], "MCU1_0.StartUpTask", elcount(mcu1_0_tasks[0]) - 1);
  strncat(mcu1_0_tasks[1], "MCU1_0.ShutdownTask", elcount(mcu1_0_tasks[1]) - 1);
  strncat(mcu1_0_tasks[2], "MCU1_0.SciServerLowOsTask", elcount(mcu1_0_tasks[2]) - 1);
  strncat(mcu1_0_tasks[3], "MCU1_0.SciServerHighOsTask", elcount(mcu1_0_tasks[3]) - 1);
  strncat(mcu1_0_tasks[4], "MCU1_0.Safety_WdgTask_10ms", elcount(mcu1_0_tasks[4]) - 1);
  strncat(mcu1_0_tasks[5], "MCU1_0.Safety_Task_Init", elcount(mcu1_0_tasks[5]) - 1);
  strncat(mcu1_0_tasks[6], "MCU1_0.Safety_Task_200ms", elcount(mcu1_0_tasks[6]) - 1);
  strncat(mcu1_0_tasks[7], "MCU1_0.Safety_Task_01_10", elcount(mcu1_0_tasks[7]) - 1);
  strncat(mcu1_0_tasks[8], "MCU1_0.Safety_Task_00_10", elcount(mcu1_0_tasks[8]) - 1);
  strncat(mcu1_0_tasks[9], "MCU1_0.QM_Task_Init", elcount(mcu1_0_tasks[9]) - 1);
  strncat(mcu1_0_tasks[10], "MCU1_0.QM_Task_200ms", elcount(mcu1_0_tasks[10]) - 1);
  strncat(mcu1_0_tasks[11], "MCU1_0.QM_Task_01_10ms", elcount(mcu1_0_tasks[11]) - 1);
  strncat(mcu1_0_tasks[12], "MCU1_0.QM_Task_00_10ms", elcount(mcu1_0_tasks[12]) - 1);
  strncat(mcu1_0_tasks[13], "MCU1_0.QM_MemTask_10ms", elcount(mcu1_0_tasks[13]) - 1);
  strncat(mcu1_0_tasks[14], "MCU1_0.QM_DiagTask_10ms", elcount(mcu1_0_tasks[14]) - 1);
  strncat(mcu1_0_tasks[15], "MCU1_0.QM_ComTask_5ms", elcount(mcu1_0_tasks[15]) - 1);
  strncat(mcu1_0_tasks[16], "MCU1_0.QM_ComTask_10ms", elcount(mcu1_0_tasks[16]) - 1);
  strncat(mcu1_0_tasks[17], "MCU1_0.IdleTask_OsCore0", elcount(mcu1_0_tasks[17]) - 1);
  strncat(mcu1_0_tasks[18], "MCU1_0.BootAppOsTask", elcount(mcu1_0_tasks[18]) - 1);
  
  // Initialize MCU2_1 task names (ORIGINAL ORDER - matches data order)
  for (j = 0; j < 10; j++) mcu2_1_tasks[j][0] = '\0';
  strncat(mcu2_1_tasks[0], "MCU2_1.en_TasK_SAFETY_BSW_10msec", elcount(mcu2_1_tasks[0]) - 1);
  strncat(mcu2_1_tasks[1], "MCU2_1.en_Task_SAFETY_APP_50msec", elcount(mcu2_1_tasks[1]) - 1);
  strncat(mcu2_1_tasks[2], "MCU2_1.en_TasK_APP_QM_10msec", elcount(mcu2_1_tasks[2]) - 1);
  strncat(mcu2_1_tasks[3], "MCU2_1.en_Task_APP_B_10msec", elcount(mcu2_1_tasks[3]) - 1);
  strncat(mcu2_1_tasks[4], "MCU2_1.en_Task_en_TasK_BSW_QM_HighPriority_OnEvent", elcount(mcu2_1_tasks[4]) - 1);
  strncat(mcu2_1_tasks[5], "MCU2_1.en_TasK_BSW_QM1_10msec", elcount(mcu2_1_tasks[5]) - 1);
  strncat(mcu2_1_tasks[6], "MCU2_1.en_TasK_BSW_QM_10msec", elcount(mcu2_1_tasks[6]) - 1);
  strncat(mcu2_1_tasks[7], "MCU2_1.en_Task_BSW_B_10msec", elcount(mcu2_1_tasks[7]) - 1);
  strncat(mcu2_1_tasks[8], "MCU2_1.en_Task_BSW_B_1msec", elcount(mcu2_1_tasks[8]) - 1);
  strncat(mcu2_1_tasks[9], "MCU2_1.en_Task_BSW_B_Idle", elcount(mcu2_1_tasks[9]) - 1);
  
  // Initialize MCU2_0 task names (ORIGINAL ORDER - matches data order)
  for (j = 0; j < 8; j++) mcu2_0_tasks[j][0] = '\0';
  strncat(mcu2_0_tasks[0], "MCU2_0.en_Task_APP_B_30msec", elcount(mcu2_0_tasks[0]) - 1);
  strncat(mcu2_0_tasks[1], "MCU2_0.en_TasK_APP_QM_10msec", elcount(mcu2_0_tasks[1]) - 1);
  strncat(mcu2_0_tasks[2], "MCU2_0.en_Task_APP_B_10msec", elcount(mcu2_0_tasks[2]) - 1);
  strncat(mcu2_0_tasks[3], "MCU2_0.en_TasK_BSW_QM_TI_10msec", elcount(mcu2_0_tasks[3]) - 1);
  strncat(mcu2_0_tasks[4], "MCU2_0.en_Task_en_TasK_BSW_QM_HighPriority_OnEvent", elcount(mcu2_0_tasks[4]) - 1);
  strncat(mcu2_0_tasks[5], "MCU2_0.en_TasK_BSW_QM1_10msec", elcount(mcu2_0_tasks[5]) - 1);
  strncat(mcu2_0_tasks[6], "MCU2_0.en_TasK_BSW_QM_10msec", elcount(mcu2_0_tasks[6]) - 1);
  strncat(mcu2_0_tasks[7], "MCU2_0.en_Task_BSW_B_10msec", elcount(mcu2_0_tasks[7]) - 1);
  
  // Validate file path and open file
  setFilePath(path, 1);
  logFile = openFileWrite("StackUsage_FDF8.txt", 2);
  if (logFile == 0)
  {
    write("Error: Failed to open file at path %s", path);
    testStepFail("Failed to open log file!");
    return;
  }
  
  for (i = 1; i <= iterations; i++)
  {
    write("Starting iteration %d", i);
    
    offset = 3;  // Reset to skip positive response (0x62 0xFD 0xF8) for each iteration
    
    if (i > 1 && waitTime > 0)
    {
      testWaitForTimeout(waitTime);
    }
   
    // Read Stack Usage
    Set_Extended_Session();
    req.SendRequest();
    resp_diag = testWaitForDiagResponse(req, 10000);
    if (resp_diag == 0)
    {
      write("Error: No response for read request");
      testStepFail("Stack Usage Read - No Response!");
      snprintf(temp, elcount(temp), "Iteration %d: Stack Usage Read - No Response\n", i);
      filePutString(temp, strlen(temp), logFile);
      continue;
    }
    
    diagGetLastResponse(resp);
    resp_diag = diagGetResponseCode(resp);
    write("Read response code: %d", resp_diag);
    
    if (resp_diag == -1)
    {
      testStepPass("Stack Usage Read Successful!");
    }
    else
    {
      testStepFail("","Stack Usage Read Failed! Response code: %d", resp_diag);
      snprintf(temp, elcount(temp), "Iteration %d: Stack Usage Read Failed, code: %d\n", i, resp_diag);
      filePutString(temp, strlen(temp), logFile);
      continue;
    }
    
    // Get response data
    len = diagGetPrimitiveData(resp, response, 500);
    write("Response length: %d bytes", len);
    snprintf(temp, elcount(temp), "Iteration %d: Response length = %d bytes\n", i, len);
    filePutString(temp, strlen(temp), logFile);
    
    if (len <= 0)
    {
      write("Error: No data received in response");
      testStepFail("No data in Stack Usage response!");
      snprintf(temp, elcount(temp), "Iteration %d: No data received\n", i);
      filePutString(temp, strlen(temp), logFile);
      continue;
    }
    
    // Convert byte array to hex string
    outBuffer[0] = 0;
    for (j = 0; j < len; j++)
    {
      char tmpHex[10];
      snprintf(tmpHex, elcount(tmpHex), "%02X ", response[j]);
      strncat(outBuffer, tmpHex, elcount(outBuffer) - strlen(outBuffer) - 1);
      if ((j + 1) % 16 == 0)
      {
        strncat(outBuffer, "\n", elcount(outBuffer) - strlen(outBuffer) - 1);
      }
    }
    
    // Log hex to test report and file
    testStepPass("StackUsage (Hex)", "%s", outBuffer);
    snprintf(temp, elcount(temp), "Iteration %d: StackUsage Hex Data:\n%s\n", i, outBuffer);
    filePutString(temp, strlen(temp), logFile);
    
    // Parse and log stack usage values - SIMPLE APPROACH
    if (len < 37)
    {
      snprintf(temp, elcount(temp), "Warning: Response too short for full parsing (%d bytes)\n", len);
      filePutString(temp, strlen(temp), logFile);
    }
    
    // MCU1_0 section: Parse data in ORIGINAL ORDER but STORE for later
    
    snprintf(temp, elcount(temp), "Rx\t    MCU1_0\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 19 && offset + j < len; j++)
    {
      mcu1_0_values[j] = response[offset + j];
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
      if ((j + 1) % 16 == 0 && j < 18)
      {
        snprintf(temp, elcount(temp), "\nRx\t\t    ");
        filePutString(temp, strlen(temp), logFile);
      }
    }
    snprintf(temp, elcount(temp), "\n");
    filePutString(temp, strlen(temp), logFile);
    
    // NOW PRINT MCU1_0 IN REVERSE ORDER (from last task to first)
    for (j = 18; j >= 0; j--)
    {
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %d [%%]\n", mcu1_0_tasks[j], mcu1_0_values[j]);
      filePutString(temp, strlen(temp), logFile);
    }
    offset += 19;
    snprintf(temp, elcount(temp), "\n");
    filePutString(temp, strlen(temp), logFile);
    
    // MCU2_1 section: Parse data in ORIGINAL ORDER but STORE for later
    
    snprintf(temp, elcount(temp), "Rx\t    MCU2_1\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 10 && offset + j < len; j++)
    {
      mcu2_1_values[j] = response[offset + j];
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
    }
    snprintf(temp, elcount(temp), "\n");
    filePutString(temp, strlen(temp), logFile);
    
    // NOW PRINT MCU2_1 IN REVERSE ORDER (from last task to first)
    for (j = 9; j >= 0; j--)
    {
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %d [%%]\n", mcu2_1_tasks[j], mcu2_1_values[j]);
      filePutString(temp, strlen(temp), logFile);
    }
    offset += 10;
    snprintf(temp, elcount(temp), "\n");
    filePutString(temp, strlen(temp), logFile);
    
    // MCU2_0 section: Parse data in ORIGINAL ORDER but STORE for later
    
    snprintf(temp, elcount(temp), "Rx\t    MCU2_0\t    ");
    filePutString(temp, strlen(temp), logFile);
    for (j = 0; j < 8 && offset + j < len; j++)
    {
      mcu2_0_values[j] = response[offset + j];
      snprintf(temp, elcount(temp), "0x%02X ", response[offset + j]);
      filePutString(temp, strlen(temp), logFile);
    }
    snprintf(temp, elcount(temp), "\n");
    filePutString(temp, strlen(temp), logFile);
    
    // NOW PRINT MCU2_0 IN REVERSE ORDER (from last task to first)
    for (j = 7; j >= 0; j--)
    {
      snprintf(temp, elcount(temp), "Rx\t    %s\t    %d [%%]\n", mcu2_0_tasks[j], mcu2_0_values[j]);
      filePutString(temp, strlen(temp), logFile);
    }
    offset += 8;
    snprintf(temp, elcount(temp), "\n");
    filePutString(temp, strlen(temp), logFile);
  }
  
  fileClose(logFile);
  testStepPass("Stack Usage test completed successfully");
}

void appendToString(char dest[], char src[], int destSize)
{
  char temp[5000];
  snprintf(temp, elcount(temp), "%s%s", dest, src);
  snprintf(dest, destSize, "%s", temp);
}

export testcase Stack_Usage_MCU2_1(int iterations, char command[], char path[])
{
  long SecureUnlock, MCU2_0_resp;
  int i = 0;
  
  setFilePath(path, 1);
  testStep("","%s from %s", command, path);
  for (i = 1; i <= iterations; i++)
  {
    SecureUnlock = testWaitForSyscall(path,"python SecureUnlock.py", 0, 35000);
    if(SecureUnlock == 1)
    {
      testWaitForTimeout(10000);
    }
    else
    {
      testStepFail("ECU did not Unlock!");
    }
    MCU2_0_resp = testWaitForSyscall(path, command, 0, 600000);
  
    if (MCU2_0_resp !=1 )
    {
      testStepFail("","Failed to retieve cpu load data from MCU2_0 core!");
    }
    else
    {
      testStepPass();
    }
  }
}

export testcase CPU_Load_Test_MCU2_0(int iterations, char command[], char path[])
{
  long SecureUnlock, MCU2_0_resp;
  int i = 0;

  setFilePath(path, 1);
  testStep("","%s from %s", command, path);
  for (i = 1; i <= iterations; i++)
  {
    SecureUnlock = testWaitForSyscall(path,"python SecureUnlock.py", 0, 35000);
    if(SecureUnlock == 1)
    {
      testWaitForTimeout(10000);
    }
    else
    {
      testStepFail("ECU did not Unlock!");
    }
    MCU2_0_resp = testWaitForSyscall(path, command, 0, 600000);
  
    if (MCU2_0_resp == 2 )
    {
      testStepFail("","Failed to retieve cpu load data from MCU2_0 core!");
    }
    else
    {
      testStepPass();
    }
  }
}

export testcase CPU_Load_Test_MCU2_1(int iterations, char command[], char path[])
{
  long SecureUnlock, MCU2_1_resp;
  int i =0;
  setFilePath(path, 1);
  testStep("","%s from %s", command, path);
  for (i = 1; i <=iterations; i++)
  {
    SecureUnlock = testWaitForSyscall(path,"python SecureUnlock.py", 0, 35000);
    if(SecureUnlock == 1)
    {
      testWaitForTimeout(10000);
    }
    else
    {
      testStepFail("ECU did not Unlock!");
    }
    MCU2_1_resp = testWaitForSyscall(path, command, 0, 600000);
  
    if (MCU2_1_resp == 2 )
    {
      testStepFail("","Failed to retieve cpu load data from MCU2_1 core!");
    }
    else
    {
      testStepPass();
    }
  }
}



