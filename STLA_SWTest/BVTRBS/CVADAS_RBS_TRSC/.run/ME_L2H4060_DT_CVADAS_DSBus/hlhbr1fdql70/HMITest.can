export testcase HMI_Frame_Rate_Test(char resolution[])
{
  long iter;
  long lastView;
  char imageName[20];
  char lastImageName[20];
  char iterInString[5];
  
  iter = 0;
  lastView = 2;
  
  General_Precondition();
  
  Switch_Gear_With_String("P");
  
  strncpy(lastImageName, resolution, 20);
  strncat(lastImageName, "_old", 20);;
  ltoa(lastView, iterInString, 20);
  write(iterInString);
  strncat(lastImageName, iterInString, 20);
  
  Capture_Image(lastImageName, resolution);
  
  for (iter = 14; iter >= 1; iter--)
  {
    if(iter == 4 || iter == 10)
    {
      continue;
    }
    testStep("", "Start frame rate testing for %s", viewName[iter]);
    
    testStep("", "Switch view to %s", viewName[iter]);
    $CameraDisplaySts2 = iter;
    
    strncpy(imageName, resolution, 20);
    strncat(imageName, "_", 20);
    ltoa(iter, iterInString, 10);
    strncat(imageName, iterInString, 20);
    
    Capture_Image(imageName, resolution);
    
    if(Get_Comparison_Score(lastImageName, imageName, resolution) > 0.95)
    {
      testStepFail("", "failed to view swtich from %s to %s", viewName[lastView], viewName[iter]);
    }
    else
    {
      testStepPass("", "View switched");
    }
    
    testStep("", "Wait for 20 minutes");
    testWaitForTimeout(1200000);
    
    strncpy(lastImageName, imageName, 20);
    lastView = iter;
  }
  
  General_Postcondition();
}

void Retry(char functionName[])
{
  int retries;
  long response;
  
  retries = 0;
  do
  {
    if(retries == 0)
    {
      testStep("", "Try %s", functionName);
    }
    else
    {
      testStep("", "Retry %s, error code %d", functionName, response);
    }
    if(strncmp(functionName, "Set_Default_Session", 19) == 0)
    {
      response = Set_Default_Session();
    }
    else if(strncmp(functionName, "Set_Extended_Session", 20) == 0)
    {
      response = Set_Extended_Session();
    }
    else if(strncmp(functionName, "Hard_Reset", 10) == 0)
    {
      response = Hard_Reset();
    }
    else
    {
      testStepFail("", "Function not found to retry");
      return;
    }
    
    testStep("", "Wait for 250 ms");
    testWaitForTimeout(250);
    
    if(response == 1){
      testStepPass("","%s succeeded", functionName);
      return;
    }
    
    retries += 1;
  }
  while(retries < 3);
  testStepFail("","%s failed, error code: %d", functionName, response);
}

void Retry_With_Arguments(char functionName[], char arguments[][])
{
  int retries;
  long response;
  
  retries = 0;
  do
  {
    if(retries == 0)
    {
      testStep("", "Try %s", functionName);
    }
    else
    {
      testStep("", "Retry %s, error code %d", functionName, response);
    }
    if(strncmp(functionName, "Write_Proxi", 11) == 0)
    {
      response = Write_Proxi(arguments[0]);
    }
    else
    {
      testStepFail("", "Function not found to retry");
      return;
    }
    
    testStep("", "Wait for 250 ms");
    testWaitForTimeout(250);
    
    if(response == 1){
      testStepPass("","%s succeeded", functionName);
      return;
    }
    
    retries += 1;
  }
  while(retries < 3);
  testStepFail("","%s failed, error code: %d", functionName, response);
}

long Set_Default_Session()
{
  long response;
  diagRequest CVADAS_0001_00000000_000.Default_Session_Start defaultSessionStart;
  diagResponse CVADAS_0001_00000000_000.Default_Session_Start defaultSessionStartResp;
  
  testStep("","Set Default Session");
  defaultSessionStart.SendRequest();
  TestWaitForDiagRequestSent(defaultSessionStart, 1000);
  response = TestWaitForDiagResponse(defaultSessionStart, 1000);
  
  return response;
  
}

long Set_Extended_Session()
{
  long response;
  diagRequest CVADAS_0001_00000000_000.Extended_Diagnostic_Session_Start extendedSessionStart;
  
  testStep("","Set Extended Session");
  extendedSessionStart.SendRequest();
  TestWaitForDiagRequestSent(extendedSessionStart, 1000);
  response = TestWaitForDiagResponse(extendedSessionStart, 1000);
  return response;
  
}

long Hard_Reset()
{
  long response;
  diagRequest CVADAS_0001_00000000_000.HardReset_Reset hardReset;
  
  testStep("","ECU hard reset");
  hardReset.SendRequest();
  TestWaitForDiagRequestSent(hardReset, 1000);
  response = TestWaitForDiagResponse(hardReset, 1000);

  return response;
}

long Write_Proxi(char proxi[])
{
  long response;
  diagRequest CVADAS_0001_00000000_000._2E2023_PROXI_Data proxiData;
  
  testStep("", "Write proxi data");
  proxiData.SetParameter("_Data_24", proxi);
  proxiData.SendRequest();
  response = TestWaitForDiagResponse(proxiData, 1000);
  if(response == 1)
  {
    response = diagGetLastResponseCode(proxiData);
    if(response == -1)
    {
      return 1;
    }
    if(response == 1){
      return -1;
    }
  }
  return response;
}

long Test_Pattern_Start(char cameraIdentifier[])
{
  long response;
  diagRequest CVADAS_0001_00000000_000._3101FE0E_Test_Pattern_Control_Start req;
  diagResponse CVADAS_0001_00000000_000._3101FE0E_Test_Pattern_Control_Start resp;
    
  testStep("", "Test pattern start with %s", cameraIdentifier);
  req.SetParameter("Camera_Identifier", cameraIdentifier);
  req.SetParameter("Test_Pattern", "100% Vertical Color Bars Test Pattern");
  req.SendRequest();
  response = TestWaitForDiagRequestSent(req, 2000);
  if(response != 1) return response;
  response = TestWaitForDiagResponse(req, 2000);
  if(response != 1) return response;
  
  diagGetLastResponse(resp);
  response = diagGetResponseCode(resp);
  if(response != -1) return response;
  return 1;
}

long Test_Pattern_Stop()
{
  long response;
  diagRequest CVADAS_0001_00000000_000._3102FE0E_Test_Pattern_Control_Stop req;
  diagResponse CVADAS_0001_00000000_000._3102FE0E_Test_Pattern_Control_Stop resp;
  
  testStep("", "Test pattern stop");
  req.SendRequest();
  response = TestWaitForDiagRequestSent(req, 2000);
  if(response != 1) return response;
  response = TestWaitForDiagResponse(req, 2000);
  if(response != 1) return response;
  
  diagGetLastResponse(resp);
  response = diagGetResponseCode(resp);
  if(response != -1) return response;
  return 1;
  
}

long Check_FD_CAN_2_trace()
{
   if(((timeNowFloat() / 100) - timeSinceLastFDCAN2) <= 200) return 1;
   else return 0;
}

export void Disable_CAN_Communication()
{
  long response, j;
  dword context;
  
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 0;
  if($CameraDisplaySts2 == 0) testStepPass("", "Set view to default");
  else testStepFail("", "Failed to set view to default, current view = %s", viewName[(int)$CameraDisplaySts2]);
  
  Switch_Gear_With_String("P");
  
  $CmdIgnSts = 0;
  
  testStep("", "Wait for 250ms");
  testWaitForTimeout(250);
  
  testStepPass("", "$CmdIgnSts set to 'lock'");
  //if($CmdIgnSts == 0) testStepPass("", "$CmdIgnSts set to 'lock'");
  //else testStepFail("", "$CmdIgnSts failed to set to 'lock', current $CmdIgnSts = %d", $CmdIgnSts);
  
  @sysvar::IL::Klemme15=0;
  @sysvar::IL::Klemme30=0;
  if(@sysvar::IL::Klemme15==0) testStepPass("", "Ignition turned off");
  else testStepFail("", "Ignition failed to turn off");
  if(@sysvar::IL::Klemme30==0) testStepPass("", "Can bus power turned off");
  else testStepFail("", "Can bus power failed to turn off");
  
  response = diagStopTesterPresent(ecuName);
  if(response != 0) testStepFail("", "Failed to stop Tester Present, error: %d", response);
  else testStep("", "Stopped Tester Present");
  
  j = 0;
  while(j < 6)
  {
    testStep("", "Wait for 2 seconds");
    testWaitForTimeout(2000);
    
    j++;
    
    if(((timeNowFloat() / 100) - timeSinceLastFDCAN2) >= 3000 && ((timeNowFloat() / 100) - timeSinceLastFDCAN14) >= 3000)
    {
      testStepPass("", "ECU went to sleep");
      break;
    }
  }
  
  if(j >= 6) testStepWarning("", "ECU failed to sleep in 12 seconds");
  while(j < 6)
  {
    testStep("", "Wait for 2 seconds");
    testWaitForTimeout(2000);
    j++;
  }
}

export void Enable_CAN_Communication(char gear[])
{
  long response;
  dword context;
  
  @sysvar::IL::Klemme15=1;
  @sysvar::IL::Klemme30=1;
  if(@sysvar::IL::Klemme15==1) testStepPass("", "Ignition turned on");
  else testStepFail("", "Ignition failed to turn on");
  if(@sysvar::IL::Klemme30==1) testStepPass("", "Can bus power turned on");
  else testStepFail("", "Can bus power failed to turn on");
  //change to 250ms 8-23-23
  testWaitForTimeout(350);
  testStep("","Wait for 350ms");
  
  $CmdIgnSts = 4;
  testStepPass("", "$CmdIgnSts set to 'run'");
  //if($CmdIgnSts == 4) testStepPass("", "$CmdIgnSts set to 'run'");
  // else testStepFail("", "$CmdIgnSts failed to set to 'run', current $CmdIgnSts = %d", $CmdIgnSts);
  //change to 2000ms
  teststep("","wait for 2750ms");
  testWaitForTimeout(2750);
  
  
  
  testStep("", "Set view to default");
  $CameraDisplaySts2 = 0;
  if($CameraDisplaySts2 == 0) testStepPass("", "Set view to default");
  else testStepFail("", "Failed to set view to default, current view = %s", viewName[(int)$CameraDisplaySts2]);
  teststep("","wait for 1000ms");
  testWaitForTimeout(1000);
 
  Switch_Gear_With_String("P");
  
  teststep("","wait for 650ms");
  testWaitForTimeout(650);
  testStep("", " $FDCAN2::CVADAS::CVPAM_FD_Info::DisplayView2 = %d",  $FDCAN2::CVADAS::CVPAM_FD_Info::DisplayView2);
  
  Switch_Gear_With_String(gear);
  setTimer(t, 800);
  
  //If needed comment-in for TTFI
  
//  testStep("", "Reset timer for TTFI and can wake up");
//  lastCANSleep = timeNowFloat() / 100.0;
//  timeForFDCAN2Wake = 0;
//  timeForFDCAN14Wake = 0;

  response = diagStartTesterPresent(ecuName);
  
  if(response != 0) testStepFail("", "Failed to start Tester Present, error: %d", response);
  else testStep("", "Started Tester Present");
  
}

export void Time_To_View_Switch_From_Reverse(char prevImageName[])
{
  long i, j;
  char batchFileNameWithASpace [50] = "Image_Comparison.bat ";
  char fullCommand [256] = "";
  long response;
  float switchTime;
  char takenImageName[16];
  
  Switch_Gear_With_String("R");
  
  strncpy(fullCommand, batchFileNameWithASpace, 256);
  strncat(fullCommand, "1200x900 checkWhenSwitchAway ", 256); 
  strncat(fullCommand, "prevImageName", 256);
  
  testStep("", "start looking for the first valid image");
  response = testWaitForSyscall(pythonFolder, fullCommand, 0, 300000);
  
  if(response == 1)
  {
    char buffer[64];
    char bufferA[64];
    char bufferB[64];
    char beforeImagePath[500];
    char afterImagePath[500];
    dword glbHandle = 0;
    dword glbHandleA = 0;
    dword glbHandleB = 0;
    
    setFilePath (pythonFolder, 0);
    glbHandle = OpenFileRead ("switchTime.txt", 0);

    if ( glbHandle!=0 )
    {
      fileGetStringSZ(buffer,elcount(buffer),glbHandle);
      switchTime = atodbl (buffer);
      fileClose (glbHandle);
      if (switchTime < 0) 
      {
        switchTime *= -1;
        testStepFail(" ", "Failed to maintain correct display after received first image");
      }
      else
      {
        testStepPass("", "spent %f seconds to receive first valid image", switchTime);
      }
      
      glbHandleB = OpenFileRead ("beforeSwitch.txt", 0);
      glbHandleA = OpenFileRead ("afterSwitch.txt", 0);
      
      if ( glbHandleA != 0 && glbHandleB != 0)
      {
        long k;
        fileGetStringSZ(bufferB,elcount(buffer),glbHandleB);
        fileGetStringSZ(bufferA,elcount(buffer),glbHandleA);
        
        fileClose(glbHandleA);
        fileClose(glbHandleB);
        
        strncpy(beforeImagePath, pythonFolder, 500);
        strncat(beforeImagePath, bufferB, 500);
        strncpy(afterImagePath, pythonFolder, 500);
        strncat(afterImagePath, bufferA, 500);
       
        
        testReportAddImage("before", beforeImagePath);
        testReportAddImage("after", afterImagePath);
        
        for(k = 0; k < 15; k++)
        {
          takenImageName[k] = bufferA[k+7];
        }
        response = Check_If_Black_Screen(takenImageName, "1200x900");
        if(response == 1) testStepFail("", "Unexpected blackscreen detected!");
        
      }
      else
      {
        write ("File 'beforeSwitch.txt' or 'afterSwitch.txt' was not opened for read access.");
        testStepFail("File 'beforeSwitch.txt' or 'afterSwitch.txt' was not opened for read access.");
      }
      
    }
    else
    {
      write ("File 'switchTime.txt' was not opened for read access.");
      testStepFail("File 'switchTime.txt' was not opened for read access.");
    }
  }
  else
  {
    write ("failed to finish TTFI test, exit code: %d", response);
    testStepFail(" ", "failed to finish TTFI test, exit code: %d", response);
  }
}

long Check_FD_CAN_14_trace()
{
   if(((timeNowFloat() / 100) - timeSinceLastFDCAN14) <= 200) return 1;
   else return 0;
}

long Check_Both_Can_Messages()
{
  long gotBothMessages;
  
  gotBothMessages = 1;
  if(Check_FD_CAN_2_trace() != 1)
  {
    testStepFail("", "No FDCAN2 message!");
    gotBothMessages = 0;
  }
  if(Check_FD_CAN_14_trace() != 1)
  {
    testStepFail("", "No FDCAN14 message!");
    gotBothMessages = 0;
  }
  return gotBothMessages;
}

