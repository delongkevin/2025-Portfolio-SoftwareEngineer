{
  long i;
  for(i = 0; i < 10; i++)
  {
    Clear_DTC();
    Check_DTC();
  }
}

export testfunction Capture_And_Compare_G_V_S(int gear, int view, int speed)
{
  char masterImageName[50];
  char viewInString[5];
  char speedInString[5];
  
  strncpy(masterImageName, "1200x900_", 30);
  strncat(masterImageName, gearName[gear], 30);
  strncat(masterImageName, "_V", 30);
  ltoa(view, viewInString, 10);
  strncat(masterImageName, viewInString, 30);
  strncat(masterImageName, "_S", 30);
  ltoa(speed, speedInString, 10);
  strncat(masterImageName, speedInString, 30);
  
  if(view == 0) Capture_And_Compare(masterImageName, "1", "1200x900");
  else Capture_And_Compare(masterImageName, viewInString, "1200x900");
}
