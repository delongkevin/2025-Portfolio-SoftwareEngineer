# GM VIP Automation – E-mail configuration
#
# Copy this file to .env (same directory) and fill in your settings.
# The .env file is loaded automatically by email_report.py.
# Lines starting with # are comments.
#
# IMPORTANT: Never commit a .env file that contains real passwords.
#            The .gitignore already excludes .env.
# ==========================================================================

# --------------------------------------------------------------------------
# SMTP server settings
# --------------------------------------------------------------------------

# Hostname of your SMTP relay or e-mail provider.
# Corporate example : mailrelay.example.com
# Gmail example     : smtp.gmail.com  (use port 587, TLS=true)
# Office 365 example: smtp.office365.com  (port 587, TLS=true)
# Local relay       : localhost  (port 25, TLS=false)
EMAIL_SMTP_HOST=localhost

# SMTP port.
#   587  – most relays with STARTTLS (recommended)
#   465  – SSL/TLS-only (set EMAIL_USE_SSL=true)
#    25  – unauthenticated local relay
EMAIL_SMTP_PORT=587

# Sender credentials.  The USERNAME is also used as the "From" address.
EMAIL_SMTP_USER=gm-vip-automation@example.com
EMAIL_SMTP_PASS=your-smtp-password-here

# STARTTLS (true recommended for port 587)
EMAIL_USE_TLS=true

# SSL mode – only set to true when using port 465 (implicit TLS)
EMAIL_USE_SSL=false

# --------------------------------------------------------------------------
# Recipients
# --------------------------------------------------------------------------

# Comma-separated list of e-mail addresses to receive every report.
EMAIL_RECIPIENTS=team-lead@example.com,qa-manager@example.com

# --------------------------------------------------------------------------
# Sender display name shown in e-mail clients
# --------------------------------------------------------------------------
EMAIL_FROM_NAME=GM VIP Automation
